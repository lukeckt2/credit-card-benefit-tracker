# Environment: "prod" (default) or "dev"
# When set to "dev", config resolves DEV_DATABASE_HOST before DATABASE_HOST, etc.
# APP_ENV=prod

DATABASE_HOST=host.docker.internal
DATABASE_PORT=3306
DATABASE_NAME=credit_card_benefits
DATABASE_USER=credit_card_db_user
DATABASE_PASSWORD=
DATABASE_DRIVER=mysql+pymysql

# Optional separate migration/admin credentials. Create/use only after approval.
MIGRATION_DATABASE_HOST=127.0.0.1
MIGRATION_DATABASE_PORT=3306
MIGRATION_DATABASE_NAME=credit_card_benefits
MIGRATION_DATABASE_USER=credit_card_admin_user
MIGRATION_DATABASE_PASSWORD=
MIGRATION_DATABASE_DRIVER=mysql+pymysql

# Dev environment overrides (used when APP_ENV=dev)
# Only the values that differ need a DEV_ prefix; the rest fall through.
# DEV_DATABASE_HOST=192.168.0.215
# DEV_MIGRATION_DATABASE_HOST=192.168.0.215

ADMIN_LOCAL_ONLY=true
APP_PORT=8787
BACKUP_DIR=./backups
